# =============================================================================
# OpsTronic Configuration
# =============================================================================

# LLM Configuration
GEMINI_API_KEY=your_gemini_api_key_here
GROQ_API_KEY=your_groq_api_key_here

# GitHub Integration
GITHUB_TOKEN=your_github_token_here
DEFAULT_REPO=Himanhuthegr8/OpsTronic
ENVIRONMENT=development
FRONTEND_URL=http://localhost:5173
CORS_ALLOWED_ORIGINS=http://localhost:5173

# ChromaDB (Runbooks)
CHROMA_PERSIST_DIR=./db/chroma_data

# =============================================================================
# Supabase Configuration (Database + Auth)
# =============================================================================
SUPABASE_URL=https://xsztdqdtqkmpqczqyzdu.supabase.co
SUPABASE_ANON_KEY=your_publishable_key_here
SUPABASE_SERVICE_KEY=your_secret_key_here

# =============================================================================
# Webhook Security
WEBHOOK_SECRET=generate_a_random_webhook_secret_here
ALLOW_INSECURE_WEBHOOKS=false

# =============================================================================
# Twilio Configuration (Voice Calls)
# =============================================================================
TWILIO_ACCOUNT_SID=your_twilio_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_PHONE_NUMBER=your_twilio_from_number_here
ALERT_PHONE_NUMBER=+919876543210

# =============================================================================
# Service Authentication (GitHub Actions → Agent)
# =============================================================================
SERVICE_API_KEY=generate_a_random_32_char_string_here

DEPLOYMENT_WATCH_MINUTES=5
MAX_LOG_CHARS=30000
INCIDENT_RCA_COOLDOWN_MINUTES=15
INGEST_RATE_LIMIT_PER_MINUTE=60
RCA_RATE_LIMIT_PER_MINUTE=6
