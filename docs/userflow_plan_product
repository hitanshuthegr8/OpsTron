## Phase 5 — Fix Connection Verification (Replace Simulate Button)

**File:** `frontend/onboarding.html` — **[MODIFY]**

Replace the fake `simulateDockerConnect()` with real polling:

```javascript
let heartbeatPollInterval = null;

function startHeartbeatPolling() {
    const statusEl = document.getElementById('agent-status');
    const btn = document.getElementById('btn-next-docker');
    let attempts = 0;
    const maxAttempts = 30; // 60 seconds at 2s intervals

    statusEl.innerHTML = `
        <div class="agent-waiting">
            <div class="spinner"></div>
            <span>Waiting for agent to connect... (${maxAttempts * 2}s timeout)</span>
        </div>`;

    heartbeatPollInterval = setInterval(async () => {
        attempts++;
        try {
            const res = await fetch(`${BACKEND}/agent/status`);
            const data = await res.json();

            if (data.status === 'connected') {
                clearInterval(heartbeatPollInterval);
                statusEl.innerHTML = `
                    <div class="success-card">
                        <div class="success-icon">🟢</div>
                        <h3>Agent Connected!</h3>
                        <p>Monitoring <strong>${data.monitored_containers?.length || 0}</strong>
                           containers on <code>${data.hostname}</code></p>
                    </div>`;
                btn.disabled = false;
                toast('OpsTron agent is live!', 'success');
                return;
            }
        } catch (e) { /* backend not ready yet */ }

        if (attempts >= maxAttempts) {
            clearInterval(heartbeatPollInterval);
            statusEl.innerHTML = `
                <div style="color:var(--warning)">
                    ⚠️ Agent not detected after 60 seconds.
                    Make sure the container is running and OPSTRON_BACKEND_URL is correct.
                    <br><br>
                    <button class="btn btn-secondary btn-sm" onclick="startHeartbeatPolling()">
                        Retry Detection
                    </button>
                </div>`;
        }
    }, 2000);
}
```

