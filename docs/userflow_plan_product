await redis.setex(
    f"apikey:{agent_api_key}",
    86400 * 30,  # 30 days
    github_user_id
)
```

### 3c. Scoped Heartbeat Endpoint

**File:** `agent/app/api/routes/ingest.py` — **[MODIFY]**

Heartbeat is now scoped per user so two users' agents don't overwrite each other:

```python
class HeartbeatPayload(BaseModel):
    agent_version: str = "unknown"
    hostname: str = "unknown"
    monitored_containers: list[str] = []

@router.post("/agent/heartbeat", dependencies=[Depends(verify_api_key)])
async def agent_heartbeat(
    payload: HeartbeatPayload,
    agent_identity: dict = Depends(verify_api_key)  # gets user_id from key
):
    redis = await get_redis()
    user_id = agent_identity["user_id"]

    heartbeat_data = {
        "last_seen": datetime.utcnow().isoformat(),
        "hostname": payload.hostname,
        "agent_version": payload.agent_version,
        "monitored_containers": payload.monitored_containers,
    }
    # KEY IS NOW SCOPED: agent:{user_id}:heartbeat
    # Two users can have agents running simultaneously without collision
    await redis.setex(f"agent:{user_id}:heartbeat", 90, json.dumps(heartbeat_data))
    logger.info(f"[HEARTBEAT] User {user_id} | Agent alive on {payload.hostname}")
    return {"status": "ok", "message": "Heartbeat received"}


@router.get("/agent/status")
async def get_agent_status(user: dict = GitHubAuth):
    """Returns the current user's agent status."""
    redis = await get_redis()
    user_id = str(user["github_id"])
    raw = await redis.get(f"agent:{user_id}:heartbeat")
    if not raw:
        return {"status": "offline", "message": "No agent connected."}
    data = json.loads(raw)
    ttl = await redis.ttl(f"agent:{user_id}:heartbeat")
    return {
        "status": "connected",
        "last_seen": data["last_seen"],
        "hostname": data["hostname"],
        "ttl_seconds": ttl,
        "monitored_containers": data.get("monitored_containers", [])
    }
```

