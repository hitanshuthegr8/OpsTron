### 7a. Add two missing tables to schema.sql

**File:** `agent/app/db/schema.sql` — **[MODIFY]**

```sql
-- Table: OpsTron Users (one row per GitHub user who signs up)
CREATE TABLE IF NOT EXISTS opstron_users (
  id UUID PRIMARY KEY DEFAULT uuid_generate_v4(),
  github_id TEXT NOT NULL UNIQUE,
  github_login TEXT NOT NULL,
  github_token TEXT,                    -- OAuth token (for API calls)
  agent_api_key TEXT NOT NULL UNIQUE,   -- their X-API-Key for the agent
  phone_number TEXT,                    -- for Twilio alerts
  created_at TIMESTAMPTZ DEFAULT NOW()
);

CREATE INDEX ON opstron_users(agent_api_key);  -- fast key lookup
CREATE INDEX ON opstron_users(github_id);

-- Table: Connected Repos (which repos each user has added)
CREATE TABLE IF NOT EXISTS connected_repos (
  id UUID PRIMARY KEY DEFAULT uuid_generate_v4(),
  user_id UUID REFERENCES opstron_users(id) ON DELETE CASCADE,
  repo_full_name TEXT NOT NULL,          -- "owner/repo"
  webhook_id INTEGER,                    -- GitHub webhook ID
  webhook_active BOOLEAN DEFAULT FALSE,
  connected_at TIMESTAMPTZ DEFAULT NOW()
);

-- Add user_id to existing tables (scope data per user)
ALTER TABLE deployments ADD COLUMN IF NOT EXISTS user_id UUID REFERENCES opstron_users(id);
ALTER TABLE rca_logs ADD COLUMN IF NOT EXISTS user_id UUID REFERENCES opstron_users(id);
```

