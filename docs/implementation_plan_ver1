## Phase 2 — ARQ Worker (The RCA Engine)

This is the most important phase. The worker is a **separate process** that picks up jobs from Redis and runs the full RCA pipeline.

### 2a. Create Queue Helper

**File:** `agent/app/core/queue.py` — **[NEW]**

> [!IMPORTANT]
> Uses **ARQ's native `enqueue_job()`** — not manual `LPUSH`. This gives us built-in retry, job metadata tracking, timeout enforcement, and dead-letter handling for free.

```python
"""
Job queue interface using ARQ native API.

FastAPI calls enqueue_rca_job() → ARQ handles serialization,
retry, timeout, and job tracking automatically.
The ARQ Worker process picks up and executes run_rca_pipeline.
"""
import json
import logging
from arq import create_pool
from arq.connections import RedisSettings
from fastapi import HTTPException
from app.core.config.settings import settings

logger = logging.getLogger(__name__)

# ARQ pool — lazily initialized, shared across all requests
_arq_pool = None


async def get_arq_pool():
    """Get or create the ARQ Redis pool (singleton)."""
    global _arq_pool
    if _arq_pool is None:
        _arq_pool = await create_pool(
            RedisSettings.from_dsn(settings.REDIS_URL)
        )
        logger.info("ARQ pool initialized")
    return _arq_pool


async def close_arq_pool():
    """Close ARQ pool on app shutdown."""
    global _arq_pool
    if _arq_pool:
        await _arq_pool.aclose()
        _arq_pool = None


async def enqueue_rca_job(payload_dict: dict) -> str:
    """
    Enqueue an RCA job using ARQ's native job system.

    ARQ handles:
    - Serialization of payload
    - Job ID generation and tracking
    - Automatic retry on worker crash
    - Job timeout enforcement
    - Dead-letter if all retries exhausted

    Returns the ARQ job_id string for client polling.
    """
    pool = await get_arq_pool()

    # --- Backpressure: reject if queue is overloaded ---
    queue_info = await pool.queued_jobs()
    if len(queue_info) >= settings.MAX_QUEUE_LENGTH:
        logger.warning(f"[QUEUE] Overloaded: {len(queue_info)} jobs pending")
        raise HTTPException(
            status_code=503,
            detail={
                "status": "overloaded",
                "queue_depth": len(queue_info),
                "message": f"Queue full ({settings.MAX_QUEUE_LENGTH} max). Retry in 30 seconds."
            }
        )

    # Enqueue via ARQ — returns a Job object with .job_id
    job = await pool.enqueue_job(
        "run_rca_pipeline",   # must match function name in worker.py
        payload_dict,         # passed as first arg to the function
        _job_try=1,
        _defer_by=None,
    )

    logger.info(f"[QUEUE] Job {job.job_id} enqueued ({len(queue_info) + 1} in queue)")
    return job.job_id


async def get_job_result(job_id: str) -> dict | None:
    """
    Get job status/result from ARQ.
    ARQ stores job info in Redis under arq:result:{job_id}.
    """
    pool = await get_arq_pool()
    job = await pool.job(job_id)
    if not job:
        return None

    job_info = await job.info()
    if job_info is None:
        return {"status": "queued", "job_id": job_id}

    result = await job.result(timeout=0)  # non-blocking check

    if result is not None:
        return {"status": "complete", "job_id": job_id, "report": result}

    return {"status": job_info.status.value, "job_id": job_id}
```

### 2b. Create the ARQ Worker

**File:** `agent/worker.py` — **[NEW]** (sits next to `main.py`)

```python
"""
OpsTron ARQ Worker — RCA Processing Engine

Run this as a separate process:
    arq worker.WorkerSettings

This worker pulls jobs from Redis and runs the full RCA pipeline.
It is completely independent of the FastAPI process.
"""
import json
import logging
import asyncio
import hashlib
from datetime import datetime
from arq import create_pool
from arq.connections import RedisSettings

from app.core.config.settings import settings
from app.core.orchestrator import RCAOrchestrator
from app.models.error_models import ErrorPayload

logger = logging.getLogger(__name__)

# One orchestrator per worker process (not per request)
_orchestrator: RCAOrchestrator | None = None


def get_orchestrator() -> RCAOrchestrator:
    global _orchestrator
    if _orchestrator is None:
        _orchestrator = RCAOrchestrator()
    return _orchestrator


async def run_rca_pipeline(ctx, payload_dict: dict):
    """
    ARQ task — called natively by ARQ when a job is dequeued.

    Signature matches ARQ convention:
      ctx:          ARQ job context (has ctx['redis'], ctx['job_id'])
      payload_dict: the dict passed to pool.enqueue_job()

    ARQ automatically:
    - Passes ctx with redis connection and job metadata
    - Retries this function on crash (up to max_tries)
    - Enforces job_timeout — kills if exceeded
    - Marks job as failed in dead-letter after max_tries exhausted

    Return value is stored by ARQ and retrievable via job.result()
    """
    job_id = ctx["job_id"]  # ARQ injects this automatically
    logger.info(f"[WORKER] Processing job {job_id}")

    orchestrator = get_orchestrator()

    try:
        from app.models.error_models import ErrorPayload
        payload = ErrorPayload(**payload_dict["error_payload"])
        metadata = payload_dict.get("metadata", {})
        deployment_context = payload_dict.get("deployment_context")

        if deployment_context:
            metadata["deployment_context"] = deployment_context

        result = await orchestrator.analyze(
            service=payload.service,
            repo=payload_dict.get("repo", settings.DEFAULT_REPO),
            log_text=payload_dict.get("log_text", ""),
            metadata=metadata
        )

        logger.info(f"[WORKER] Job {job_id} complete")
        # Return value stored by ARQ, retrieved via get_job_result()
        return {
            "status": "complete",
            "report": result,
            "completed_at": datetime.utcnow().isoformat()
        }

    except Exception as e:
        logger.exception(f"[WORKER] Job {job_id} failed: {e}")
        # Raising lets ARQ handle retry logic
        raise


class WorkerSettings:
    """ARQ worker configuration."""
    functions = [run_rca_pipeline]          # functions this worker handles
    redis_settings = RedisSettings.from_dsn(settings.REDIS_URL)
    max_jobs = 4                            # concurrent RCA jobs per worker process
    job_timeout = 120                       # seconds — kill job if exceeded
    max_tries = 3                           # retry failed jobs up to 3 times
    keep_result = settings.JOB_RESULT_TTL_SECONDS  # how long ARQ keeps result in Redis
    retry_jobs = True                       # retry on crash/timeout
```

