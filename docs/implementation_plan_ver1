## Phase 4 — Parallel Agent Execution

**File:** `agent/app/core/orchestrator.py`

Run LogAgent and CommitAgent in parallel (they are independent). RunbookAgent needs LogAgent output, so it runs after.

```python
async def analyze(self, service, repo, log_text, metadata=None):

    # Phase 1: Parallel — LogAgent + CommitAgent
    log_task = self.log_agent.analyze(log_text)
    commit_task = self.commit_agent.analyze(repo)

    log_analysis, commit_analysis = await asyncio.gather(
        log_task, commit_task, return_exceptions=True
    )

    # Handle failures gracefully
    if isinstance(log_analysis, Exception):
        logger.error(f"LogAgent failed: {log_analysis}")
        log_analysis = {"error_signals": [], "key_errors": [], "patterns": []}

    if isinstance(commit_analysis, Exception):
        logger.error(f"CommitAgent failed: {commit_analysis}")
        commit_analysis = {"commits": [], "error": str(commit_analysis)}

    # Phase 2: RunbookAgent (needs log signals)
    try:
        error_signals = log_analysis.get("error_signals", [])
        runbook_results = await self.runbook_agent.search(error_signals)
    except Exception as e:
        logger.error(f"RunbookAgent failed: {e}")
        runbook_results = []

    # Phase 3: Synthesize
    rca_report = await self.synthesizer_agent.synthesize(
        service=service,
        log_analysis=log_analysis,
        commit_analysis=commit_analysis,
        runbook_results=runbook_results,
        metadata=metadata
    )

    # Voice alert (if deployment regression)
    if rca_report.get("is_deployment_caused") or rca_report.get("is_deployment_regression"):
        asyncio.create_task(self._trigger_voice_alert(...))

    return rca_report
```

