### 3c. Move DeploymentWatcher to Redis

Replace the in-memory `DeploymentWatcher` class with Redis-backed helpers:

```python
async def _register_deployment_in_redis(redis, payload: DeploymentPayload) -> str:
    deployment_id = f"deploy-{uuid.uuid4().hex[:8]}"
    record = {
        "deployment_id": deployment_id,
        "commit_sha": payload.commit_sha,
        "repository": payload.repository,
        "author": payload.author,
        "message": payload.message,
        "branch": payload.branch,
        "registered_at": datetime.utcnow().isoformat(),
    }
    ttl = settings.DEPLOYMENT_WATCH_MINUTES * 60
    await redis.setex(f"deploy:active:{deployment_id}", ttl, json.dumps(record))
    await redis.setex("deploy:current", ttl, deployment_id)  # pointer to latest
    return deployment_id


async def _get_active_deployment_from_redis(redis) -> dict | None:
    dep_id = await redis.get("deploy:current")
    if not dep_id:
        return None
    raw = await redis.get(f"deploy:active:{dep_id}")
    return json.loads(raw) if raw else None
```

